{
  "tags": [
    "activity"
  ],
  "summary": "List user activity posts",
  "description": "Retrieve paginated activity posts for a specific user.",
  "properties": {
    "peopleUid": {
      "type": "uid"
    },
    "institutionUid": {
      "type": "uid"
    },
    "page": {
      "type": "string",
      "pattern": "^\\d+$"
    }
  },
  "oneOf": [ 
    { "required": [peopleUid] },
    { "required": [institutionUid] }
  ]
}
