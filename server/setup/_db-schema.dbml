Table city {
  id int [pk, increment]
  name varchar(250) [not null, unique, note: 'Nome']
  state_id int [not null, ref: > state.id, note: 'Estado']
  Note: 'Cidade'
}

Table country {
  id int [pk, increment]
  code varchar(250) [not null, unique, note: 'Codigo']
  name varchar(250) [not null, unique, note: 'Nome']
  Note: 'Pais'
}

Table friend {
  id int [pk, increment]
  accepted_at timestamp [note: 'Aceitado Em']
  friend_id int [not null, ref: > people.id, note: 'Amigo']
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  request_at timestamp [not null, note: 'Pedido Em']
  Note: 'Amigo'
}

Table institution {
  id int [pk, increment]
  address text [not null, unique, note: 'Endereço']
  avatar text [note: 'Avatar']
  banner text [note: 'banner']
  city_id int [not null, ref: > city.id, note: 'Cidade']
  cover_image text [note: 'Imagem de capa']
  description text [not null, note: 'Descrição']
  email varchar(250) [not null, note: 'E-mail']
  logo text [note: 'Logotipo']
  name varchar(250) [not null, note: 'Nome']
  post_code varchar(250) [not null, unique, note: 'Código Postal']
  telephone int [not null, note: 'Telefone']
  website varchar(250) [unique, note: 'Website']
  Note: 'Instituição'
}

Table notification {
  id int [pk, increment]
  content text [note: 'Conteúdo']
  extra text [note: 'Dados Adicionais']
  originator_id int [ref: > people.id, note: 'Originador']
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  read_at timestamp [note: 'Lido Em']
  recipient_id int [not null, ref: > people.id, note: 'Destinatário']
  sent_at timestamp [not null, note: 'Enviado Em']
  title varchar(250) [not null, note: 'Título']
  type_id int [not null, ref: > notification_type.id, note: 'Tipo']
  Note: 'Notificação'
}

Table notification_opt_out {
  id int [pk, increment]
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  type_id int [not null, ref: > notification_type.id, note: 'Tipo']
  Note: 'Bloqueios'
}

Table notification_type {
  id int [pk, increment]
  code varchar(250) [not null, unique, note: 'Código']
  name varchar(250) [not null, unique, note: 'Name']
  Note: 'Tipo'
}

Table people {
  id int [pk, increment]
  avatar text [note: 'Avatar']
  banner text [note: 'Banner']
  birth_date date [not null, note: 'Data de Nascimento']
  city_id int [not null, ref: > city.id, note: 'Cidade']
  cover_image text [note: 'Imagem de capa']
  description text [not null, note: 'Descrição']
  email varchar(250) [not null, unique, note: 'Email']
  institution_id int [not null, ref: > institution.id, note: 'Instituição']
  name varchar(250) [not null, note: 'Nome']
  order varchar(250) [not null, unique, note: 'Ordem']
  people_user_id int [not null, unique, note: 'Utilizador']
  recovery_key varchar(250) [note: 'Chave de Recuperação']
  recovery_limit timestamp [note: 'Limite de Recuperação']
  Note: 'Pessoa'
}

Table people_ws_session {
  id int [pk, increment]
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  session_id varchar(250) [not null, note: 'Sessão ID']
  Note: 'Sessão WS'
}

Table post {
  id int [pk, increment]
  comments int [note: 'Comentários']
  content text [not null, note: 'Conteúdo']
  likes int [note: 'Likes']
  moment timestamp [not null, note: 'Momento']
  parent_id int [ref: > post.id, note: 'Pai']
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  Note: 'Publicação'
}

Table post_like {
  id int [pk, increment]
  moment timestamp [not null, note: 'Momento']
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  post_id int [not null, ref: > post.id, note: 'Publicação']
  Note: 'Like'
}

Table state {
  id int [pk, increment]
  code varchar(250) [not null, unique, note: 'Codigo']
  country_id int [not null, ref: > country.id, note: 'Pais']
  name varchar(250) [not null, unique, note: 'Nome']
  Note: 'Estado'
}

